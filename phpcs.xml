<?xml version="1.0"?>
<ruleset name="CloudScale Backup &amp; Restore">
    <description>WordPress Coding Standards configuration for CloudScale Backup &amp; Restore.</description>

    <file>.</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/playwright-report/*</exclude-pattern>

    <rule ref="WordPress">
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="csbr" />
                <element value="CSBR" />
                <element value="CloudScale" />
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="cloudscale-backup-restore" />
            </property>
        </properties>
    </rule>

    <config name="minimum_supported_wp_version" value="6.0" />
    <config name="testVersion" value="8.1-" />
</ruleset>
